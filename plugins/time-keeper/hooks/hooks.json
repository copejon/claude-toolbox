{
  "description": "Inject current date/time at session start",
  "hooks": {
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "bash \"${CLAUDE_PLUGIN_ROOT}/hooks/inject-time.sh\"",
            "timeout": 5
          }
        ]
      }
    ]
  }
}
